# ─────────────────────────────────────────────────────────────────────────────
# Tautulli
# Base URL of your Tautulli instance (no trailing slash).
TAUTULLI_URL=https://tautulli.example.com
# Tautulli API key — found under Settings → Web Interface → API Key.
TAUTULLI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Radarr
# Base URL of your Radarr instance (no trailing slash).
RADARR_URL=https://radarr.example.com
# Radarr API key — found under Settings → General → Security → API Key.
RADARR_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Sonarr
# Base URL of your Sonarr instance (no trailing slash).
SONARR_URL=https://sonarr.example.com
# Sonarr API key — found under Settings → General → Security → API Key.
SONARR_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# App configuration
# Port the Express backend listens on inside Docker.
BACKEND_PORT=3001
# Port the Vite frontend listens on inside Docker.
FRONTEND_PORT=5173
# Public URL of the app (used for any absolute links).
APP_URL=http://localhost:5173
# URL the Vite dev server proxies /api requests to.
# Use http://localhost:3001 for local (non-Docker) development.
# Docker Compose automatically overrides this to http://backend:3001.
BACKEND_PROXY_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Access (optional)
# Required only if your Radarr/Sonarr/Tautulli instances are protected by
# Cloudflare Zero Trust Access. Create a Service Token in:
#   Zero Trust → Access → Service Auth → Service Tokens
# Then add a "Service Auth" policy to each application that includes the token.
# Leave blank if Cloudflare Access is not in use.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Excluded Plex users (optional)
# Comma-separated list of Plex usernames to hide from the user selector.
# Useful for hiding admin or service accounts that should not be searched.
# Example: EXCLUDED_PLEX_USERS=admin,homeserver,testuser
EXCLUDED_PLEX_USERS=
